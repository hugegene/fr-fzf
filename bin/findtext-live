#!/bin/zsh
# Usage: findtext-live [path]
# Live grep across [path] (default: .) — query updates results per keystroke.

local target="${1:-.}"
local GREP="grep -rn --color=always"

: | fzf --ansi --disabled \
  --delimiter : \
  --header "Type to grep | ENTER: Open in Micro | CTRL-G: Copy Code | CTRL-\\\\: Toggle Preview | ESC: Back" \
  --bind "change:reload:sleep 0.1; [ -n {q} ] && $GREP -- {q} $target 2>/dev/null | sed 's|^\\./||' || true" \
  --preview 'L={2}; S=$((L>5?L-5:1)); bat --color=always --line-range "$S:+15" {1} --highlight-line {2}' \
  --preview-window=right:60%:wrap \
  --bind 'enter:execute(micro +{2} {1})' \
  --bind 'ctrl-g:execute-silent(L={2}; S=$((L>5?L-5:1)); E=$((L+10)); p={1}; case "$p" in /*) abs="$p" ;; *) abs="$PWD/$p" ;; esac; { printf "%s\n" "$abs"; sed -n "${S},${E}p" {1}; } | pbcopy)' \
  --bind 'ctrl-\:change-preview-window(99%|hidden|)'
